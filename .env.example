# Relay Proxy Environment Variables

# The active provider for the proxy (openai, anthropic, copilot, generic)
RELAY_PROVIDER=openai

# OpenAI Provider
OPENAI_API_KEY=sk-your-openai-key

# Anthropic Provider
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Generic Provider (e.g. Ollama, Azure, vLLM)
GENERIC_API_KEY=your-optional-generic-key
GENERIC_BASE_URL=http://localhost:11434

# Copilot Provider
# If using Copilot, you must accept the terms by setting this to false
# COPILOT_REQUIRE_CONSENT=false

# Server Configuration
# The port the relay proxy will bind to inside the container
RELAY_PORT=8080
# The host interface to bind to (0.0.0.0 is recommended for Docker)
RELAY_HOST=0.0.0.0
